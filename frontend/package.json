{
  "name": "attendance-frontend",
  "version": "1.0.0",
  "scripts": {
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "app.js",
      "utils/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "verbose": true,
    "transform": {}
  }
}